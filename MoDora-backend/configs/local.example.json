{
  "env": "dev",
  "service_name": "modora-backend",
  "log_level": "INFO",
  "log_format": "text",
  "log_to_file": false,
  "log_dir": null,

  "// Data paths": "Data and cache directories",
  "docs_dir": "./datasets/MMDA",
  "cache_dir": "./cache",
  "chroma_persist_path": "./cache/chroma",

  "// API 配置": "Used for external LLM API calls (OpenAI, Gemini, etc.)",
  "api_base": "https://api.openai.com/v1",
  "api_key": "your-api-key",
  "api_model": "gpt-4o",
  "embedding_api_base": "https://api.openai.com/v1",
  "embedding_api_key": "your-api-key",
  "embedding_model_name": "text-embedding-3-large",
  "rerank_api_base": null,
  "rerank_api_key": null,
  "rerank_model_name": null,

  "model_instances": {
    "local-default": {
      "type": "local",
      "model": "./models/Qwen3-VL-8B-Instruct",
      "port": 9001,
      "device": "0"
    },
    "remote-default": {
      "type": "remote",
      "model": "gpt-5",
      "base_url": "https://your-api-base-url/v1",
      "api_key": "your-api-key"
    }
  },

  "// OCR 配置": "Structural recognition based on PaddleOCR (ppstructure or paddle_ocr_vl)",
  "ocr_model": "ppstructure",
  "ocr_device": "gpu:0",
  "ocr_lang": "en",
  "ocr_layout_unclip_ratio": 1.2,
  "ocr_text_recognition_batch_size": 8,
  "ocr_use_table_recognition": true,
  "ocr_use_doc_unwarping": false,

  "ui_settings": {
    "schemaVersion": 3,
    "pipelines": {
      "enrichment": { "modelInstance": "local-default" },
      "levelGenerator": { "modelInstance": "local-default" },
      "metadataGenerator": { "modelInstance": "local-default" },
      "retriever": { "modelInstance": "local-default" },
      "qaService": { "modelInstance": "local-default" }
    }
  }
}
